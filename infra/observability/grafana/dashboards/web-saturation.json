{
  "_header": {
    "purpose": "Web application saturation dashboard showing ECS Fargate CPU, memory, and request concurrency metrics",
    "scope": "Production ECS Fargate task resource utilization including CPU, memory, and HTTP concurrency",
    "overview": "Extracts the Saturation - Production (ECS Fargate) row from the golden signals overview into a dedicated detail dashboard. Displays ECS CPU and memory utilization from CloudWatch, request concurrency from Mimir, and stat panels for per-service CPU and memory percentages. Enables focused investigation of resource saturation patterns for the production web application.",
    "dependencies": "CloudWatch datasource (uid: cloudwatch) for ECS metrics, Mimir datasource (uid: mimir) for http_active_connections",
    "exports": "Provisioned Grafana dashboard accessible at /grafana/d/web-saturation",
    "interfaces": "CloudWatch queries for AWS/ECS namespace, PromQL for http_active_connections gauge",
    "environment": "Identical across dev/staging/prod; ECS cluster and service names are environment-specific",
    "related": "web-summary.json for overview, obs-saturation.json for observability stack saturation",
    "implementation": "Grafana dashboard JSON schema version 39 with CloudWatch and Mimir datasource queries"
  },
  "uid": "web-saturation",
  "title": "Saturation",
  "description": "Is the backend running out of resources? CPU and memory utilization from CloudWatch ECS Container Insights show whether Fargate tasks are hitting their limits. The request concurrency panel shows active in-flight connections from the application itself. During an incident: if CPU is red (>90%) the task is compute-bound — consider scaling. If memory is red (>90%) you risk OOM kills. If concurrency is climbing while CPU/memory are low, the bottleneck is external (database, downstream API).",
  "tags": ["web"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Home",
      "url": "/grafana/d/home",
      "type": "link",
      "icon": "home",
      "keepTime": true,
      "includeVars": false
    },
    {
      "title": "Summary",
      "url": "/grafana/d/web-summary",
      "type": "link",
      "icon": "dashboard",
      "keepTime": true,
      "includeVars": true
    },
    {
      "title": "Web Dashboards",
      "type": "dashboards",
      "tags": ["web"],
      "asDropdown": true,
      "keepTime": true,
      "includeVars": true
    }
  ],
  "panels": [
    {
      "type": "text",
      "title": "",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 8,
      "options": {
        "mode": "markdown",
        "content": "# Saturation\nIs the backend running out of resources? CPU and memory utilization from ECS show whether Fargate tasks are hitting their limits. Red (>90%) means the task is resource-bound. If concurrency is climbing while CPU/memory are low, the bottleneck is external (database, downstream API)."
      }
    },
    {
      "type": "timeseries",
      "title": "ECS CPU Utilization",
      "description": "CPU usage of backend and frontend ECS Fargate tasks as a percentage of their allocated CPU limit. Green (<70%) means headroom. Yellow (70-90%) means the task is working hard. Red (>90%) means CPU-bound — requests will queue and latency will spike. If this is red, check if scaling out or optimizing hot code paths (see Profiling dashboard) would help.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 3 },
      "id": 1,
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "targets": [
        {
          "namespace": "AWS/ECS",
          "metricName": "CPUUtilization",
          "statistics": ["Average"],
          "dimensions": {
            "ClusterName": ["durable-code-dev-cluster"],
            "ServiceName": ["durable-code-dev-backend"]
          },
          "period": "60",
          "refId": "A",
          "id": "",
          "region": "default",
          "label": "Backend CPU"
        },
        {
          "namespace": "AWS/ECS",
          "metricName": "CPUUtilization",
          "statistics": ["Average"],
          "dimensions": {
            "ClusterName": ["durable-code-dev-cluster"],
            "ServiceName": ["durable-code-dev-frontend"]
          },
          "period": "60",
          "refId": "B",
          "id": "",
          "region": "default",
          "label": "Frontend CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "ECS Memory Utilization",
      "description": "Memory usage of backend and frontend ECS Fargate tasks as a percentage of their allocated memory limit. A steadily rising line indicates a memory leak. A sudden jump to red (>90%) means OOM kill risk — ECS will terminate and replace the task, causing a brief outage. If memory is high, check the Profiling dashboard for memory allocation flame graphs.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 3 },
      "id": 2,
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "targets": [
        {
          "namespace": "AWS/ECS",
          "metricName": "MemoryUtilization",
          "statistics": ["Average"],
          "dimensions": {
            "ClusterName": ["durable-code-dev-cluster"],
            "ServiceName": ["durable-code-dev-backend"]
          },
          "period": "60",
          "refId": "A",
          "id": "",
          "region": "default",
          "label": "Backend Memory"
        },
        {
          "namespace": "AWS/ECS",
          "metricName": "MemoryUtilization",
          "statistics": ["Average"],
          "dimensions": {
            "ClusterName": ["durable-code-dev-cluster"],
            "ServiceName": ["durable-code-dev-frontend"]
          },
          "period": "60",
          "refId": "B",
          "id": "",
          "region": "default",
          "label": "Frontend Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Request Concurrency",
      "description": "Number of HTTP requests being processed simultaneously by the backend. Peak and average lines help distinguish burst traffic from sustained load. Rising concurrency with flat CPU/memory means requests are waiting on something external (database, downstream service). Rising concurrency with high CPU means the backend itself is the bottleneck.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 3 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(http_active_connections)",
          "legendFormat": "Peak concurrent",
          "refId": "A"
        },
        {
          "expr": "avg_over_time(sum(http_active_connections)[$__rate_interval])",
          "legendFormat": "Avg concurrent",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "type": "stat",
      "title": "Backend CPU %",
      "description": "Current backend CPU utilization. Red (>90%) means the backend is CPU-starved — latency and errors will follow.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 11 },
      "id": 4,
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "targets": [
        {
          "namespace": "AWS/ECS",
          "metricName": "CPUUtilization",
          "statistics": ["Average"],
          "dimensions": {
            "ClusterName": ["durable-code-dev-cluster"],
            "ServiceName": ["durable-code-dev-backend"]
          },
          "period": "60",
          "refId": "A",
          "id": "",
          "region": "default"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
